<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/styles.css" rel="stylesheet">
    <!-- Prefetch main pages for instant navigation -->
    <% const locBase = (typeof location !== 'undefined' && location && !location.isDefault) ? '/' + location.slug : ''; %>
    <link rel="prefetch" href="<%= locBase %>/">
    <link rel="prefetch" href="<%= locBase %>/submit">
    <link rel="prefetch" href="<%= locBase %>/reviews">
    <link rel="prefetch" href="<%= locBase %>/raffles">
    <link rel="prefetch" href="<%= locBase %>/merchants">
    <link rel="prefetch" href="<%= locBase %>/how-it-works">
    <!-- Preconnect to external domains used on page -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
</head>
<body class="bg-gray-50 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm">
        <div class="max-w-6xl mx-auto px-4 py-4">
            <div class="flex justify-between items-center">
                <a href="/" class="flex items-center space-x-2">
                    <span class="text-2xl">₿</span>
                    <span class="font-bold text-xl">Reviews Raffle</span>
                </a>
                <div class="hidden md:flex items-center space-x-6">
                    <a href="<%= locBase %>/" class="text-gray-600 hover:text-bitcoin">Home</a>
                    <a href="<%= locBase %>/submit" class="text-gray-600 hover:text-bitcoin">Submit Review</a>
                    <a href="<%= locBase %>/reviews" class="text-gray-600 hover:text-bitcoin">Reviews</a>
                    <a href="<%= locBase %>/raffles" class="text-gray-600 hover:text-bitcoin">Raffles</a>
                    <a href="<%= locBase %>/merchants" class="text-gray-600 hover:text-bitcoin">Merchants</a>
                    <a href="<%= locBase %>/how-it-works" class="text-gray-600 hover:text-bitcoin">How It Works</a>
                    <% if (typeof allLocations !== 'undefined' && allLocations && allLocations.length > 1) { %>
                    <div class="relative" x-data="{ open: false }">
                        <button @click="open = !open" class="text-gray-600 hover:text-bitcoin flex items-center gap-1">
                            <span><%= (typeof location !== 'undefined' && location) ? location.emoji + ' ' + location.name : '📍' %></span>
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>
                        <div x-show="open" @click.away="open = false" x-transition class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border z-50">
                            <% allLocations.forEach(function(loc) { %>
                            <a href="/<%= loc.slug %>" class="block px-4 py-2 text-gray-700 hover:bg-orange-50 hover:text-bitcoin <%= (typeof location !== 'undefined' && location && location.slug === loc.slug) ? 'font-bold bg-orange-50' : '' %>">
                                <%= loc.emoji %> <%= loc.name %>
                            </a>
                            <% }); %>
                        </div>
                    </div>
                    <% } %>
                    <a href="/#donate" id="raffle-fund-badge" class="hidden items-center gap-1.5 bg-gradient-to-r from-orange-500 to-yellow-500 text-white px-3 py-1.5 rounded-full text-sm font-bold shadow-sm hover:shadow-md transition-all" title="Next raffle prize">
                        <span>⚡</span>
                        <span>Next Prize:</span>
                        <span id="raffle-fund-amount">0</span>
                        <span class="text-xs opacity-80">sats</span>
                        <span id="raffle-fund-usd-nav" class="hidden text-xs opacity-90 ml-1"></span>
                    </a>
                </div>
                <div class="md:hidden flex items-center gap-2">
                    <!-- Mobile prize badge — ALWAYS visible next to hamburger, not inside collapsed menu -->
                    <a href="/#donate" id="raffle-fund-badge-mobile-top" class="hidden items-center gap-1 bg-gradient-to-r from-orange-500 to-yellow-500 text-white px-2.5 py-1 rounded-full text-xs font-bold shadow-sm" title="Next raffle prize">
                        <span>⚡</span>
                        <span id="raffle-fund-usd-mobile-top" class="hidden">$0</span>
                        <span id="raffle-fund-amount-mobile-top">0</span>
                        <span class="opacity-80">sats</span>
                    </a>
                    <button id="mobile-menu-btn" class="text-gray-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </div>
            <!-- Mobile menu -->
            <div id="mobile-menu" class="hidden md:hidden mt-4 space-y-2">
                <a href="<%= locBase %>/" class="block py-2 text-gray-600 hover:text-bitcoin">Home</a>
                <a href="<%= locBase %>/submit" class="block py-2 text-gray-600 hover:text-bitcoin">Submit Review</a>
                <a href="<%= locBase %>/reviews" class="block py-2 text-gray-600 hover:text-bitcoin">Reviews</a>
                <a href="<%= locBase %>/raffles" class="block py-2 text-gray-600 hover:text-bitcoin">Raffles</a>
                <a href="<%= locBase %>/merchants" class="block py-2 text-gray-600 hover:text-bitcoin">Merchants</a>
                <a href="<%= locBase %>/how-it-works" class="block py-2 text-gray-600 hover:text-bitcoin">How It Works</a>
                <% if (typeof allLocations !== 'undefined' && allLocations && allLocations.length > 1) { %>
                <div class="border-t border-gray-200 pt-2 mt-2">
                    <span class="text-xs text-gray-400 uppercase tracking-wide">Communities</span>
                    <% allLocations.forEach(function(loc) { %>
                    <a href="/<%= loc.slug %>" class="block py-1 text-gray-600 hover:text-bitcoin pl-2 <%= (typeof location !== 'undefined' && location && location.slug === loc.slug) ? 'font-bold text-bitcoin' : '' %>">
                        <%= loc.emoji %> <%= loc.name %>
                    </a>
                    <% }); %>
                </div>
                <% } %>
                <a href="/#donate" id="raffle-fund-badge-mobile" class="hidden py-2 text-bitcoin font-bold">
                    ⚡ Next Prize: <span id="raffle-fund-amount-mobile">0</span> sats
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        <%- body %>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white mt-16">
        <div class="max-w-6xl mx-auto px-4 py-8">
            <div class="grid md:grid-cols-3 gap-8">
                <div>
                    <h3 class="font-bold text-lg mb-4">Reviews Raffle</h3>
                    <p class="text-gray-400"><%= (typeof location !== 'undefined' && location) ? location.description : 'Incentivizing Bitcoin adoption through community reviews.' %></p>
                    <% if (typeof allLocations !== 'undefined' && allLocations && allLocations.length > 1) { %>
                    <div class="mt-4">
                        <h4 class="text-sm font-semibold text-gray-300 mb-2">Communities</h4>
                        <div class="flex flex-wrap gap-2">
                            <% allLocations.forEach(function(loc) { %>
                            <a href="/<%= loc.slug %>" class="text-gray-400 hover:text-white text-sm"><%= loc.emoji %> <%= loc.name %></a>
                            <% }); %>
                        </div>
                    </div>
                    <% } %>
                </div>
                <div>
                    <h3 class="font-bold text-lg mb-4">Quick Links</h3>
                    <ul class="space-y-2 text-gray-400">
                        <li><a href="<%= locBase %>/submit" class="hover:text-white">Submit a Review</a></li>
                        <li><a href="<%= locBase %>/merchants" class="hover:text-white">Find Merchants</a></li>
                        <li><a href="<%= locBase %>/how-it-works" class="hover:text-white">How It Works</a></li>
                    </ul>
                </div>
                <div>
                    <h3 class="font-bold text-lg mb-4">Support the Raffle</h3>
                    <p class="text-gray-400 text-sm mb-3">Every sat donated goes directly into the prize pool.</p>
                    <a href="/#donate" class="inline-flex items-center gap-2 bg-bitcoin hover:bg-bitcoin-dark text-white px-4 py-2 rounded-lg text-sm font-medium transition">
                        ⚡ Donate (On-chain or Lightning)
                    </a>
                    <% if (typeof contact !== 'undefined' && contact && contact.hasAny) { %>
                    <div class="mt-5 pt-4 border-t border-gray-700">
                        <h4 class="text-sm font-semibold text-gray-300 mb-2">Contact / Feedback</h4>
                        <p class="text-gray-400 text-xs mb-2">Missing a merchant? Found a bug? Reach out:</p>
                        <div class="flex flex-wrap gap-3 text-sm">
                            <% if (contact.telegramUrl) { %>
                            <a href="<%= contact.telegramUrl %>" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-blue-400 hover:text-blue-300">
                                <span>📱</span> <span><%= contact.telegramLabel || 'Telegram' %></span>
                            </a>
                            <% } %>
                            <% if (contact.whatsappUrl) { %>
                            <a href="<%= contact.whatsappUrl %>" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-green-400 hover:text-green-300">
                                <span>💬</span> <span>WhatsApp <%= contact.whatsappLabel %></span>
                            </a>
                            <% } %>
                            <% if (contact.email) { %>
                            <a href="mailto:<%= contact.email %>?subject=Reviews%20Raffle%20feedback" class="inline-flex items-center gap-1 text-orange-300 hover:text-orange-200">
                                <span>✉️</span> <span><%= contact.email %></span>
                            </a>
                            <% } %>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
            <div class="border-t border-gray-700 mt-8 pt-8 text-center text-gray-400">
                <p><%= (typeof location !== 'undefined' && location && location.footerMadeIn) ? location.footerMadeIn : '🌴 Made with ⚡ in Roatan' %></p>
            </div>
        </div>
    </footer>

    <script>
        // Mobile menu toggle
        document.getElementById('mobile-menu-btn')?.addEventListener('click', function() {
            document.getElementById('mobile-menu').classList.toggle('hidden');
        });

        // ── Live Raffle Fund Display ──────────────────────────────────
        (function() {
            var fundBadge = document.getElementById('raffle-fund-badge');
            var fundAmount = document.getElementById('raffle-fund-amount');
            var fundUsdNav = document.getElementById('raffle-fund-usd-nav');
            var fundBadgeMobile = document.getElementById('raffle-fund-badge-mobile');
            var fundAmountMobile = document.getElementById('raffle-fund-amount-mobile');
            var fundBadgeMobileTop = document.getElementById('raffle-fund-badge-mobile-top');
            var fundAmountMobileTop = document.getElementById('raffle-fund-amount-mobile-top');
            var fundUsdMobileTop = document.getElementById('raffle-fund-usd-mobile-top');
            var homepageFund = document.getElementById('homepage-fund-amount');
            var lastAmount = -1;

            function formatSats(n) {
                return Number(n).toLocaleString();
            }

            function formatUsd(n) {
                if (n == null) return '';
                if (n >= 100) return '$' + Math.round(n).toLocaleString();
                if (n >= 1)   return '$' + n.toFixed(2);
                return '$' + n.toFixed(3);
            }

            function updateFundDisplay(sats, usd) {
                var sameSats = sats === lastAmount;
                lastAmount = sats;

                // Desktop nav badge
                if (fundBadge && fundAmount) {
                    fundAmount.textContent = formatSats(sats);
                    if (sats > 0) {
                        fundBadge.classList.remove('hidden');
                        fundBadge.classList.add('inline-flex');
                    }
                }
                if (fundUsdNav) {
                    if (usd != null && sats > 0) {
                        fundUsdNav.textContent = '(≈ ' + formatUsd(usd) + ')';
                        fundUsdNav.classList.remove('hidden');
                    } else {
                        fundUsdNav.classList.add('hidden');
                    }
                }

                // Mobile top-of-page badge (next to hamburger, always visible)
                if (fundBadgeMobileTop && fundAmountMobileTop) {
                    fundAmountMobileTop.textContent = formatSats(sats);
                    if (sats > 0) {
                        fundBadgeMobileTop.classList.remove('hidden');
                        fundBadgeMobileTop.classList.add('inline-flex');
                    }
                }
                if (fundUsdMobileTop) {
                    if (usd != null && sats > 0) {
                        fundUsdMobileTop.textContent = '≈ ' + formatUsd(usd);
                        fundUsdMobileTop.classList.remove('hidden');
                    } else {
                        fundUsdMobileTop.classList.add('hidden');
                    }
                }

                // Mobile nav badge (inside expanded menu — legacy)
                if (fundBadgeMobile && fundAmountMobile) {
                    fundAmountMobile.textContent = formatSats(sats);
                    if (sats > 0) {
                        fundBadgeMobile.classList.remove('hidden');
                        fundBadgeMobile.classList.add('block');
                    }
                }

                // Homepage donation section (if present)
                if (homepageFund) {
                    homepageFund.textContent = formatSats(sats);
                    var wrapper = document.getElementById('homepage-fund-wrapper');
                    if (wrapper && sats > 0) {
                        wrapper.classList.remove('hidden');
                    }
                }

                // Homepage hero prize-pool widget (if present)
                var heroSats = document.getElementById('hero-prize-sats');
                var heroUsd = document.getElementById('hero-prize-usd');
                var heroTotal = document.getElementById('hero-prize-total');
                var heroWrapper = document.getElementById('hero-prize-wrapper');
                if (heroSats) heroSats.textContent = formatSats(sats);
                if (heroUsd) {
                    heroUsd.textContent = usd != null ? '≈ ' + formatUsd(usd) : '';
                }
                if (heroWrapper && sats > 0) heroWrapper.classList.remove('hidden');
                // heroTotal is set from data.totalFundSats/Usd in fetchFund()
            }

            // Polling settings — designed to stay well under the public rate limit
            // (300 reqs / 15 min per IP). With 60s active polling + auto-pause when
            // tab is hidden, a single visible tab uses ~15 reqs / 15 min.
            var POLL_INTERVAL_MS = 60000;
            var pollTimer = null;
            var consecutiveFailures = 0;

            function fetchFund() {
                return fetch('/api/raffle-fund')
                    .then(function(res) {
                        if (!res.ok) {
                            // Includes 429s. Don't surface to user; just back off.
                            consecutiveFailures++;
                            return null;
                        }
                        return res.json();
                    })
                    .then(function(data) {
                        if (!data) return;
                        consecutiveFailures = 0;
                        if (data.success && typeof data.nextPrizeSats === 'number') {
                            updateFundDisplay(data.nextPrizeSats, data.nextPrizeUsd);
                            // Full fund display on homepage
                            var totalEl = document.getElementById('homepage-total-fund');
                            if (totalEl && typeof data.totalFundSats === 'number') {
                                totalEl.textContent = formatSats(data.totalFundSats);
                            }
                            var totalUsdEl = document.getElementById('homepage-total-fund-usd');
                            if (totalUsdEl) {
                                totalUsdEl.textContent = data.totalFundUsd != null
                                    ? '≈ ' + formatUsd(data.totalFundUsd)
                                    : '';
                            }
                            // Hero totals
                            var heroTotalSats = document.getElementById('hero-total-sats');
                            var heroTotalUsd = document.getElementById('hero-total-usd');
                            if (heroTotalSats) heroTotalSats.textContent = formatSats(data.totalFundSats);
                            if (heroTotalUsd) {
                                heroTotalUsd.textContent = data.totalFundUsd != null
                                    ? '≈ ' + formatUsd(data.totalFundUsd)
                                    : '';
                            }
                        }
                    })
                    .catch(function() {
                        consecutiveFailures++;
                        // silent fail
                    });
            }

            // Decide whether this page even needs the badge polling.
            // Skip on /admin (admin doesn't see the donor-facing prize pool) and
            // any page with no relevant DOM nodes — saves all those requests.
            function shouldPoll() {
                if (location.pathname.indexOf('/admin') === 0) return false;
                return !!(fundBadge || fundBadgeMobile || fundBadgeMobileTop ||
                    homepageFund || document.getElementById('hero-prize-wrapper'));
            }

            function startPolling() {
                if (pollTimer || !shouldPoll()) return;
                // Exponential backoff cap on consecutive failures (max 5 min).
                var interval = POLL_INTERVAL_MS * Math.min(1 << Math.min(consecutiveFailures, 4), 5);
                pollTimer = setInterval(function() {
                    if (document.hidden) return;  // skip silently when tab not visible
                    fetchFund();
                }, interval);
            }
            function stopPolling() {
                if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
            }

            // Pause/resume polling on tab visibility changes — biggest single win.
            document.addEventListener('visibilitychange', function() {
                if (document.hidden) {
                    stopPolling();
                } else {
                    fetchFund();   // catch up immediately when refocused
                    startPolling();
                }
            });

            // Initial fetch + polling, only if this page actually needs it
            if (shouldPoll()) {
                fetchFund();
                startPolling();
            }
        })();
    </script>
</body>
</html>
